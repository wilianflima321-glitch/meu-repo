# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aethel_db?schema=public"

# Security
JWT_SECRET="replace-with-a-random-local-jwt-secret"
CSRF_SECRET="replace-with-a-random-local-csrf-secret"

# Next.js
NODE_ENV=development
NEXT_PUBLIC_API_URL=/api

# AI providers
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AETHEL_AI_DEMO_MODE=true
AETHEL_FIRST_VALUE_SLO_MS=90000
AETHEL_FIRST_VALUE_MIN_SAMPLE=10

# Preview runtime (optional, for managed sandbox path)
AETHEL_PREVIEW_PROVIDER=
# Example route-managed provider:
# AETHEL_PREVIEW_PROVIDER=e2b
# AETHEL_PREVIEW_PROVISION_ENDPOINT=https://preview-gateway.example.com/provision
# E2B direct provision:
E2B_API_KEY=
AETHEL_PREVIEW_E2B_TEMPLATE=
AETHEL_PREVIEW_E2B_PORT=3000
# Allow remote runtime hosts (example for E2B):
AETHEL_PREVIEW_ALLOWED_HOSTS=.e2b.app
# Browser-side-only provider:
# AETHEL_PREVIEW_PROVIDER=webcontainers
AETHEL_PREVIEW_PROVISION_ENDPOINT=
AETHEL_PREVIEW_PROVISION_ENDPOINTS=
AETHEL_PREVIEW_PROVISION_TOKEN=
AETHEL_PREVIEW_PROVISION_TIMEOUT_MS=12000
AETHEL_PREVIEW_PROVISION_READY_WAIT_MS=10000
AETHEL_PREVIEW_PROVISION_READY_POLL_MS=1200

# Stripe (optional, for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_STUDIO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# AWS S3 (optional, for asset storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
